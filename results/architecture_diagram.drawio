        <mxCell id="m1" value="&lt;b&gt;Llama-2-7B-Chat (4-bit NF4 quantized)&lt;/b&gt;&lt;br&gt;Full forward pass — hidden states extracted at Layer 16 (4096-dim)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=5;" vertex="1" parent="1">
