        </mxCell>

        <mxCell id="e2" value="&lt;b&gt;SVD Decomposition&lt;/b&gt;&lt;br&gt;U_d = top-8 left singular vectors&lt;br&gt;&lt;i&gt;eff_rank = exp(&#8722;&#8721; p_i log p_i)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;arcSize=10;" vertex="1" parent="1">
