        <mxCell id="m2" value="&lt;b&gt;Classify responses:&lt;/b&gt;  refused  /  answered&lt;br&gt;H_refused, H_answered  &#8712; &#8477;&lt;sup&gt;n&times;4096&lt;/sup&gt;  per domain" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;arcSize=5;" vertex="1" parent="1">
