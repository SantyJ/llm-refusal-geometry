        <mxCell id="e1" value="&lt;b&gt;Mean-Difference Direction&lt;/b&gt;&lt;br&gt;v_d = normalize(&#956;_refuse &#8722; &#956;_answer)&lt;br&gt;&lt;i&gt;1 vector per domain (4096-dim)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;arcSize=10;" vertex="1" parent="1">
